#2. Parameterized Constructor


class Student:

    def __init__(self, name, marks):
        self.name = name
        self.marks = marks

s1 = Student("Ganesh", 95)
s2 = Student("Rahul", 88)

print(s1.name, s1.marks)
print(s2.name, s2.marks)


